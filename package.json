{
  "name": "taskfolk",
  "version": "1.0.14",
  "private": true,
  "description": "Taskfolk is a visual mission control dashboard for AI agents and shared workspace tools.",
  "main": "desktop/main.cjs",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test test/*.test.cjs",
    "desktop": "electron .",
    "desktop:dist": "electron-builder",
    "desktop:dist:mac": "electron-builder --mac --universal",
    "desktop:dist:test": "electron-builder --mac -c.mac.identity=- -c.mac.hardenedRuntime=false"
  },
  "dependencies": {
    "express": "^4.18.3",
    "multer": "^2.1.1",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.taskfolk.desktop",
    "productName": "Taskfolk",
    "forceCodeSigning": true,
    "icon": "desktop/icon.png",
    "asar": true,
    "files": [
      "desktop/**/*",
      "public/**/*",
      "server.js",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "notarize": true,
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
